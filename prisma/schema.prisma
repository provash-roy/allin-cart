generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  USER
  VENDOR
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  COD
  STRIPE
}


model User {
  id            String   @id @default(cuid())
  clerkId      String   @unique
  email         String   @unique
  firstName     String?
  lastName      String?
  image         String?
  phone         String?
  addresses     String?
  role          Role     @default(USER)

  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?



  // cart           Cart?
  vendor         Vendor?
  // wishlist       Wishlist[]
  // orders         Order[]
  // reviews        Review[]
  // notifications  Notification[]
  @@index([email])
  @@index([clerkId])
  @@map("users")
}


model Vendor {
  id              String        @id @default(cuid())
  
  vendorName      String
  addresses       String?
  approvedAt      DateTime?
  requestedAt     DateTime      @default(now())
  rejectedReason  String?

  status          VendorStatus  @default(PENDING)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("vendors")
}


